# -----------------------------------------------------------------------------
# homelab-backstage - environment variable reference
#
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#
# NEVER commit .env to git - it is listed in .gitignore.
# -----------------------------------------------------------------------------

# -- PostgreSQL ----------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=backstage
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=backstage

# -- Backstage secrets ---------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKEND_SECRET=change-me-backend-secret-32-chars-min
SESSION_SECRET=change-me-session-secret

# -- Keycloak OIDC (Backstage sign-in) ----------------------------------------
# The OIDC metadata URL is auto-discovered from the realm's well-known endpoint.
AUTH_OIDC_METADATA_URL=http://localhost:8080/realms/backstage/.well-known/openid-configuration
# Client ID of the "backstage" client in the Keycloak realm
AUTH_OIDC_CLIENT_ID=backstage
# Client secret - find it in Keycloak: Clients -> backstage -> Credentials
AUTH_OIDC_CLIENT_SECRET=change-me-in-production

# -- Keycloak catalog sync -----------------------------------------------------
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_LOGIN_REALM=master
KEYCLOAK_REALM=backstage
KEYCLOAK_CATALOG_CLIENT_ID=backstage-catalog-sync
KEYCLOAK_CATALOG_CLIENT_SECRET=change-me-catalog-sync

# -- Generic webhook backend ---------------------------------------------------
# Backstage forwards /api/webhooks/<app>/<event> to:
#   ${WEBHOOK_BASE_URL}/${WEBHOOK_TENANT-or-backstage-<env>}/<app>/<event>
WEBHOOK_BASE_URL=http://localhost:3001/api/webhooks
# Optional override; leave empty to use backstage-<auth.environment>
WEBHOOK_TENANT=

# -- GitHub (optional - for SCM integration) ----------------------------------
GITHUB_TOKEN=

# -- Production overrides (not used in local compose) -------------------------
# APP_BASE_URL=https://backstage.example.com
# BACKEND_BASE_URL=https://backstage.example.com
